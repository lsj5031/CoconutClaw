[Unit]
Description=CoconutClaw Webhook Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/code/CoconutClaw
EnvironmentFile=%h/code/CoconutClaw/.env
ExecStart=/usr/bin/python3 %h/code/CoconutClaw/services/webhook_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target

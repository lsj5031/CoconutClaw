[Unit]
Description=CoconutClaw Telegram Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/code/CoconutClaw
EnvironmentFile=%h/code/CoconutClaw/.env
ExecStart=/bin/bash -lc 'cd %h/code/CoconutClaw && ./agent.sh'
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
